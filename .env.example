# =============================================
# Okada Vet Clinic - Environment Configuration
# =============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Build with:
#   flutter run -d windows --dart-define-from-file=.env.local
#   flutter build windows --dart-define-from-file=.env.local

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Clinic Tenant
CLINIC_ID=your-clinic-uuid

# GitHub Auto-Update (optional)
GITHUB_OWNER=hieugeai-eng
GITHUB_REPO=vet-clinic
